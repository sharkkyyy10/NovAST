{
  "name": "novast",
  "version": "1.0.0",
  "description": "High-performance AST skeletonizer local daemon",
  "main": "dist/cli.js",
  "bin": {
    "novast": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:core": "cd novast-core && npm run build",
    "build:cli": "tsup",
    "postbuild": "cp novast-core/*.node ./dist/ || true",
    "build": "npm run build:core && npm run build:cli",
    "dev": "ts-node src/cli.ts"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
